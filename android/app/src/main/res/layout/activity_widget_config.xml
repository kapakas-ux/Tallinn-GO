<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Widget Setup"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#00529B"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose 1–2 stops to display"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- Search field -->
    <EditText
        android:id="@+id/config_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Search for a stop..."
        android:inputType="text"
        android:textSize="14sp"
        android:padding="12dp"
        android:background="@drawable/widget_background"
        android:layout_marginBottom="8dp"
        android:importantForAutofill="no" />

    <!-- Search results -->
    <ListView
        android:id="@+id/config_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp" />

    <!-- Selected stops -->
    <LinearLayout
        android:id="@+id/config_selected_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECTED STOPS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#999999"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/config_selected_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/config_selected_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Confirm button -->
    <android.widget.Button
        android:id="@+id/config_confirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Add Widget"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/line_badge_bus"
        android:layout_marginTop="12dp"
        android:enabled="false"
        android:alpha="0.5" />

</LinearLayout>
